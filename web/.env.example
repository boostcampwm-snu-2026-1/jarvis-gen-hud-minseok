# web 개발 환경 변수. 복사해서 .env.local 로 쓰고 값 채우기.
#   cp .env.example .env.local
# .env.local 은 절대 커밋하지 말 것 (.gitignore 의 *.local 로 무시됨).

# --- dev 프록시 전용 (Node/Vite 쪽에서만 읽힘, 클라이언트 번들에 안 들어감) ---
# Hermes OpenAI 호환 API 서버 주소. 보통 로컬 8642.
HERMES_TARGET=http://localhost:8642
# Hermes API 키. VITE_ 접두사가 없으므로 프론트 번들에 노출되지 않고,
# vite.config.ts 프록시가 Authorization: Bearer 로만 주입한다. 배포는 Caddy가 주입.
API_SERVER_KEY=

# --- 클라이언트에 노출돼도 되는 값(비밀 아님) ---
# Hermes에 보낼 모델명. 서버 기본값을 쓰려면 비워도 됨.
VITE_HERMES_MODEL=hermes
# 즉답(usher) 전용 모델 — 전송 즉시 한 문장 선응답에 쓰인다. TTFT를 줄이려면
# 빠른 메인(예: Haiku4.5)을 가리키게 둘 것. 비우면 VITE_HERMES_MODEL로 폴백.
VITE_HERMES_USHER_MODEL=
